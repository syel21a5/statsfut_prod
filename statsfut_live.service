[Unit]
Description=StatsFut Live Score Daemon
After=network.target

[Service]
User=root
Group=root
WorkingDirectory=/www/wwwroot/statsfut.com
Environment="PATH=/www/wwwroot/statsfut.com/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ExecStart=/www/wwwroot/statsfut.com/venv/bin/python manage.py live_score_daemon
Restart=always
RestartSec=60

[Install]
WantedBy=multi-user.target
